{
    "name": "ecosync-backend",
    "version": "1.0.0",
    "description": "EcoSync AI Waste Classification Backend",
    "main": "server.ts",
    "scripts": {
        "start": "node -r @swc-node/register server.ts",
        "dev": "nodemon --watch '**/*.ts' --ext ts --exec 'node -r @swc-node/register server.ts'",
        "build": "swc . -d dist --ignore node_modules,dist",
        "start:prod": "node dist/server.js"
    },
    "dependencies": {
        "@google/generative-ai": "^0.21.0",
        "@types/express-session": "^1.18.2",
        "@types/passport": "^1.0.17",
        "@types/passport-google-oauth20": "^2.0.17",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.2",
        "express-session": "^1.19.0",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.2.1",
        "nodemailer": "^8.0.1",
        "passport": "^0.7.0",
        "passport-google-oauth20": "^2.0.0"
    },
    "devDependencies": {
        "@swc-node/register": "^1.10.9",
        "@swc/cli": "^0.6.0",
        "@swc/core": "^1.11.24",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.9",
        "@types/node": "^22.0.0",
        "@types/nodemailer": "^7.0.11",
        "nodemon": "^3.1.0",
        "typescript": "^5.9.3"
    }
}
